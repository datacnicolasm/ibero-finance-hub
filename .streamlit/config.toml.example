# Tema institucional Ibero — copiar a config.toml si no está versionado.
# El repo incluye config.toml con la misma paleta para todos los entornos.

[theme]
primaryColor = "#e8c042"
backgroundColor = "#ffffff"
secondaryBackgroundColor = "#f2f1f1"
textColor = "#494646"
borderColor = "#d19e40"
showWidgetBorder = true
font = "sans serif"

[theme.sidebar]
backgroundColor = "#ececec"
secondaryBackgroundColor = "#e4e3e3"
textColor = "#494646"
borderColor = "#d19e40"

[server]
headless = true

# Streamlit Community Cloud: NO definir baseUrlPath (el health check usa /_stcore/health en la raíz).
# Subdominio público: configurar en el panel de Cloud (ej. mi-app.streamlit.app).
#
# Solo para reverse-proxy local con subpath (nginx), en una copia local NO versionada:
# baseUrlPath = "ibero-finance-hub"
